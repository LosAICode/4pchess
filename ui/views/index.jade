extends layout

block content
  div.wrapper
    div.lhs
      div.board-area
        div#board
        div#move_overlay.move-overlay
        div#player_top_left.player-badge.badge-tl
        div#player_top_right.player-badge.badge-tr
        div#player_bottom_left.player-badge.badge-bl
        div#player_bottom_right.player-badge.badge-br
    div.rhs
      div#game_title.game-title
      div.settings
        input(placeholder='Max depth')#max_depth
        input(placeholder='Max secs per move')#secs_per_move
      div.evaluation
        div#eval_estimate.eval-estimate
        div#turn_info.turn-info
        div#best_move.best-move
      div.nav-bar
        button#nav_rotate.nav-btn(title='Rotate board')
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg>
        button#nav_start.nav-btn(title='Go to start') |&#9664;
        button#nav_back4.nav-btn(title='Back 4 moves') &#9664;&#9664;
        button#nav_back1.nav-btn(title='Back 1 move') &#9664;
        button#nav_play.nav-btn.nav-play(title='Play / Pause') &#9654;
        button#nav_fwd1.nav-btn(title='Forward 1 move') &#9654;
        button#nav_fwd4.nav-btn(title='Forward 4 moves') &#9654;&#9654;
        button#nav_end.nav-btn(title='Go to end') &#9654;|
        button#play_engine_move.nav-btn.nav-engine(title='Play engine move')
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a2 2 0 012 2v1h3a3 3 0 013 3v2h1a2 2 0 110 4h-1v2a3 3 0 01-3 3h-1v2a1 1 0 11-2 0v-2h-4v2a1 1 0 11-2 0v-2H7a3 3 0 01-3-3v-2H3a2 2 0 110-4h1V8a3 3 0 013-3h3V4a2 2 0 012-2zm-2 9a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm4 0a1.5 1.5 0 100 3 1.5 1.5 0 000-3z"/></svg>
      div#theme_picker.theme-picker
        span.theme-label Board:
        button.theme-btn(data-light='#ebeae6', data-dark='#4a4c4d', title='Default')
          span.theme-swatch-light(style='background:#ebeae6')
          span.theme-swatch-dark(style='background:#4a4c4d')
        button.theme-btn(data-light='#eeeed2', data-dark='#769656', title='Green')
          span.theme-swatch-light(style='background:#eeeed2')
          span.theme-swatch-dark(style='background:#769656')
        button.theme-btn(data-light='#f5e6d0', data-dark='#a47449', title='Brown')
          span.theme-swatch-light(style='background:#f5e6d0')
          span.theme-swatch-dark(style='background:#a47449')
        button.theme-btn(data-light='#dee3e6', data-dark='#8ca2ad', title='Ice')
          span.theme-swatch-light(style='background:#dee3e6')
          span.theme-swatch-dark(style='background:#8ca2ad')
        button.theme-btn(data-light='#e8e0cc', data-dark='#5c7a36', title='Olive')
          span.theme-swatch-light(style='background:#e8e0cc')
          span.theme-swatch-dark(style='background:#5c7a36')
        button.theme-btn(data-light='#e8dfd0', data-dark='#655647', title='Walnut')
          span.theme-swatch-light(style='background:#e8dfd0')
          span.theme-swatch-dark(style='background:#655647')
      div#move_history
      div.pgn
        textarea(placeholder='Paste PGN here (e.g. from chess.com 4PC)')#pgn_input.pgn-input
        div.pgn-buttons
          button#new_game.load-pgn-btn Play
          button#open_games_btn.load-pgn-btn Open
          button#save_game_btn.load-pgn-btn Save
        div#save_game_form.save-game-form
          input(placeholder='Game name')#save_game_name.save-game-name-input
          div.save-game-form-buttons
            button#save_game_confirm.load-pgn-btn Save
            button#save_game_cancel.load-pgn-btn Cancel
        p#pgn_error.pgn-error
        div#saved_games_list.saved-games-list
